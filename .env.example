NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://learn_app:learn_app_dev@localhost:5432/learn_app?schema=public

# Generate independent random values with at least 32 characters.
JWT_ACCESS_SECRET=replace-with-a-random-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-a-random-refresh-secret-at-least-32-chars
WECHAT_OPENID_HASH_SECRET=replace-with-a-random-openid-secret-at-least-32-chars
TOKEN_HASH_SECRET=replace-with-a-random-token-secret-at-least-32-chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

WECHAT_APP_ID=replace-with-wechat-app-id
WECHAT_APP_SECRET=replace-with-wechat-app-secret
WECHAT_API_TIMEOUT_MS=5000

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=learn_app
S3_SECRET_KEY=learn_app_dev_password
S3_BUCKET=learn-app-private
S3_FORCE_PATH_STYLE=true
S3_PRESIGNED_URL_TTL_SECONDS=300

UPLOAD_MAX_FILE_SIZE_BYTES=10485760
UPLOAD_MAX_PIXELS=40000000
UPLOAD_DAILY_LIMIT=30

REDIS_URL=redis://:replace-with-redis-password@127.0.0.1:6379/0
ANALYSIS_QUEUE_NAME=analysis
ANALYSIS_QUEUE_ATTEMPTS=3
ANALYSIS_QUEUE_CONCURRENCY=1
ANALYSIS_RECONCILE_INTERVAL_MS=30000
ANALYSIS_WORKER_ENABLED=false
ANALYSIS_IDEMPOTENCY_SECRET=replace-with-an-independent-random-secret-at-least-32-chars

DIFY_BASE_URL=http://dify-api.example.internal
DIFY_ANALYSIS_API_KEY=
DIFY_ANALYSIS_TIMEOUT_MS=90000
DIFY_ANALYSIS_OUTPUT_KEY=analysis_result
DIFY_ANALYSIS_WORKFLOW_VERSION=analysis-v1
DIFY_ANALYSIS_PROMPT_VERSION=prompt-v1
DIFY_ANALYSIS_MODEL_NAME=configured-in-dify
DIFY_ANALYSIS_SCHEMA_VERSION=1.0
DIFY_KNOWLEDGE_BASE_VERSION=judgment-reasoning-v1
DIFY_ANSWER_CONFIDENCE_THRESHOLD=0.8

LOG_LEVEL=info
CORS_ORIGINS=
