NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://learn_app:learn_app_dev@localhost:5432/learn_app?schema=public

# Generate independent random values with at least 32 characters.
JWT_ACCESS_SECRET=replace-with-a-random-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-a-random-refresh-secret-at-least-32-chars
WECHAT_OPENID_HASH_SECRET=replace-with-a-random-openid-secret-at-least-32-chars
TOKEN_HASH_SECRET=replace-with-a-random-token-secret-at-least-32-chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

WECHAT_APP_ID=replace-with-wechat-app-id
WECHAT_APP_SECRET=replace-with-wechat-app-secret
WECHAT_API_TIMEOUT_MS=5000

LOG_LEVEL=info
CORS_ORIGINS=
